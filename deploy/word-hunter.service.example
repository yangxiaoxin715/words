[Unit]
Description=Word Hunter Web
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/word-hunter-web
EnvironmentFile=/etc/word-hunter/word-hunter.env
ExecStart=/opt/word-hunter-web/.venv/bin/python -m uvicorn app:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
